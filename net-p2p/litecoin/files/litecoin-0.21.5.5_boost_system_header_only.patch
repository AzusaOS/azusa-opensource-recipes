Boost.System has been header-only since Boost 1.69, and Boost 1.89 no
longer ships the stub libboost_system shared library. Make the m4 check
tolerate a missing library: the header check is what matters, and
BOOST_SYSTEM_LIB can safely be empty.

diff -rbBU3 litecoin-0.21.5.5-orig/build-aux/m4/ax_boost_system.m4 litecoin-0.21.5.5/build-aux/m4/ax_boost_system.m4
--- litecoin-0.21.5.5-orig/build-aux/m4/ax_boost_system.m4
+++ litecoin-0.21.5.5/build-aux/m4/ax_boost_system.m4
@@ -107,12 +107,6 @@
                   done

             fi
-            if test "x$ax_lib" = "x"; then
-                AC_MSG_ERROR(Could not find a version of the Boost::System library!)
-            fi
-			if test "x$link_system" = "xno"; then
-				AC_MSG_ERROR(Could not link against $ax_lib !)
-			fi
 		fi

 		CPPFLAGS="$CPPFLAGS_SAVED"
